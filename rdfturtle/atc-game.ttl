PREFIX doap: <http://usefulinc.com/ns/doap#>
PREFIX ptr:  <http://www.w3.org/2009/pointers#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX spdx: <http://spdx.org/rdf/terms#>

<http://spdx.org/licenses/atc-game>
        a                             spdx:ListedLicense;
        rdfs:seeAlso                  "https://github.com/vattam/BSDGames/blob/master/atc/extern.c#L36";
        spdx:crossRef                 [ a                   spdx:CrossRef;
                                        spdx:isLive         true;
                                        spdx:isValid        true;
                                        spdx:isWayBackLink  false;
                                        spdx:match          "false";
                                        spdx:order          "0"^^<http://www.w3.org/2001/XMLSchema#int>;
                                        spdx:timestamp      "2026-07-15T22:10:30Z";
                                        spdx:url            "https://github.com/vattam/BSDGames/blob/master/atc/extern.c#L36"
                                      ];
        spdx:isDeprecatedLicenseId    false;
        spdx:isOsiApproved            false;
        spdx:licenseText              "Copyright (c) 1987 by Ed James, UC Berkeley.  All rights reserved.\n\nCopy permission is hereby granted provided that this notice is\nretained on all partial or complete copies.\n\nFor more info on this and all of my stuff, mail edjames@berkeley.edu. \n";
        spdx:licenseTextHtml          "\n         <div class=\"replaceable-license-text\"><span title=\"can be replaced with the pattern .{0,5000}\"> \n           <p>\n              Copyright (c) 1987 by Ed James, UC Berkeley. All rights reserved.\n           </p>\n\n         </span></div>\n         <p>\n            Copy permission is hereby granted provided that this\n            notice is retained on all partial or complete copies.\n         </p>\n\n         <p>\n            For more info on this and all of my\n            stuff, mail edjames@berkeley.edu.\n         </p>\n\n      ";
        spdx:name                     "atc Game License";
        spdx:standardLicenseTemplate  "<<var;name=\"copyright\";original=\"Copyright (c) 1987 by Ed James, UC Berkeley. All rights reserved.  \";match=\".{0,5000}\">>\nCopy permission is hereby granted provided that this notice is retained on all partial or complete copies.\n\nFor more info on this and all of my stuff, mail edjames@berkeley.edu.\n\n" .
